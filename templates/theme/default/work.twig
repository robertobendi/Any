{% extends '@theme/layout.twig' %}

{% block title %}Work — Anyo at Disenyo{% endblock %}
{% block description %}Selected projects by Anyo at Disenyo — houses, interiors, and small commercial spaces across Batangas and Southern Luzon.{% endblock %}

{% set active_page = 'work' %}

{% block content %}

<section class="page-intro">
    <div class="wrap">
        <div class="offset-col">
            <span class="eyebrow">Projects · 2018 — 2024</span>
            <h1>A growing record of small, deliberate work.</h1>
            <p class="lead" style="margin-top:2rem; color:var(--ink-soft);">Most of our work begins with a long site visit and a longer conversation. The projects below — built and in progress — sit across Batangas, Cavite, and Laguna. New documentation is added as commissions complete.</p>
        </div>
    </div>
</section>

<section class="section-sm">
    <div class="wrap">

        {# ---------- PROJECT LIST ---------- #}
        {# Placeholder entries. Once the studio populates /admin/collections/projects, this template will render `entries` from the DB instead. #}

        <article class="project-card">
            <div class="frame">
                <img src="/uploads/bahay_na_bato_houses_jpg.jpg" alt="Courtyard view of a two-storey house with red-tile roof and capiz screens.">
            </div>
            <div class="head">
                <div>
                    <span class="meta">2024 · Lemery, Batangas · Architecture, Interiors</span>
                    <h3 style="margin-top:.5rem;">Casa Taal</h3>
                    <p class="descriptor">A two-storey courtyard house for an extended family, organised around an interior plaza that opens to the sky. Capiz screens filter the afternoon sun; narra floors run the length of the second storey.</p>
                </div>
                <div class="right-meta meta">
                    <div>318 sqm</div>
                    <div>Completed</div>
                </div>
            </div>
        </article>

        <article class="project-card">
            <div class="frame">
                <img src="/uploads/view_ofthe_casa_bizantina_from_the_plaza_of_las_casas_filipi.jpg" alt="Filipino-Spanish heritage house seen across a quiet plaza, late afternoon.">
            </div>
            <div class="head">
                <div>
                    <span class="meta">2023 · Lipa, Batangas · Architecture, Landscape</span>
                    <h3 style="margin-top:.5rem;">Bukal Residence</h3>
                    <p class="descriptor">A family home clad in narra and adobe, set behind a quiet street wall. Lanai and bedrooms open to a long garden that runs the length of the lot toward a row of mango trees.</p>
                </div>
                <div class="right-meta meta">
                    <div>262 sqm</div>
                    <div>Completed</div>
                </div>
            </div>
        </article>

        <article class="project-card">
            <div class="frame">
                <img src="/uploads/quema_house_outside_view_jpg.jpg" alt="Wooden capiz-screen wall of a two-storey ancestral house, monochrome.">
            </div>
            <div class="head">
                <div>
                    <span class="meta">2023 · Batangas City · Interiors</span>
                    <h3 style="margin-top:.5rem;">Studio Anyá — Wellness Fitout</h3>
                    <p class="descriptor">A 140-square-metre interior renovation of a 1960s commercial shell into a small movement studio. Lime plaster walls, narra floors, no signage out front — the building tells you what it is once you are inside.</p>
                </div>
                <div class="right-meta meta">
                    <div>140 sqm</div>
                    <div>Completed</div>
                </div>
            </div>
        </article>

        <article class="project-card">
            <div class="frame">
                <img src="/uploads/white_ancestral_house_along_calle_burgos__vigan__ilocos_sur_.jpg" alt="Weathered white facade of a Filipino ancestral house with shuttered upper windows.">
            </div>
            <div class="head">
                <div>
                    <span class="meta">2022 · Calatagan, Batangas · Architecture</span>
                    <h3 style="margin-top:.5rem;">House on the Slope</h3>
                    <p class="descriptor">A small weekend house terraced into a coastal slope. Two bedroom volumes step down the hill; the living room sits at the top with a long shaded lanai facing the sea breeze.</p>
                </div>
                <div class="right-meta meta">
                    <div>168 sqm</div>
                    <div>Completed</div>
                </div>
            </div>
        </article>

        <article class="project-card">
            <div class="frame">
                <img src="/uploads/quema_house_living_room_jpg.jpg" alt="Warm interior of an ancestral house with antique furniture, dark wood floors, and a chandelier.">
            </div>
            <div class="head">
                <div>
                    <span class="meta">2022 · Tagaytay, Cavite · Interiors</span>
                    <h3 style="margin-top:.5rem;">Patio Bahay</h3>
                    <p class="descriptor">Interior renovation of a weekend retreat. A new long table along the lanai, replanned bedrooms upstairs, and a rebuilt covered passage between the kitchen and an outdoor wood-fired oven.</p>
                </div>
                <div class="right-meta meta">
                    <div>210 sqm</div>
                    <div>Completed</div>
                </div>
            </div>
        </article>

        <article class="project-card">
            <div class="frame">
                <img src="/uploads/casamanilajf1568_06_jpg.jpg" alt="Brick-vaulted entry passage of a heritage building with palms flanking the doors.">
            </div>
            <div class="head">
                <div>
                    <span class="meta">2025 · San Pascual, Batangas · Concept</span>
                    <h3 style="margin-top:.5rem;">Café Lupa</h3>
                    <p class="descriptor">A small daytime café fitted into a former cement-block warehouse. A rammed-earth bar, a planted yard, and a covered terrace facing the street. Currently in construction.</p>
                </div>
                <div class="right-meta meta">
                    <div>96 sqm</div>
                    <div>In progress</div>
                </div>
            </div>
        </article>

    </div>
</section>

<section class="cta-strip">
    <span class="eyebrow">Begin a project</span>
    <h2 class="display" style="margin-top:1rem; font-weight:300;">Have a site, a brief, or a question?</h2>
    <p class="lead" style="max-width:46ch; margin: 1.5rem auto 2.5rem; color:var(--ink-soft);">We take on a small number of projects each year so we can stay close to each one. A short note tells us a lot.</p>
    <a class="btn btn-primary" href="/contact">Begin a project</a>
</section>

{% endblock %}
