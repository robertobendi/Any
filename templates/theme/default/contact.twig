{% extends '@theme/layout.twig' %}

{% block title %}Contact — Anyo at Disenyo, Batangas City{% endblock %}
{% block description %}Reach Anyo at Disenyo by email, phone, or inquiry form. The studio is in Batangas City and takes on a small number of projects each year.{% endblock %}

{% set active_page = 'contact' %}

{% block content %}

<section class="page-intro">
    <div class="wrap">
        <div class="offset-col">
            <span class="eyebrow">Contact</span>
            <h1>Begin a project.</h1>
            <p class="lead" style="margin-top:2rem; color:var(--ink-soft);">If you are planning a house, a renovation, or a small commercial fit-out anywhere in Calabarzon or Metro Manila, send a short note and we will get back to you within a few working days.</p>
        </div>
    </div>
</section>

<section class="section-sm">
    <div class="wrap">
        <div class="contact-grid">

            <aside class="contact-details">
                <dl>
                    <div>
                        <dt>Email</dt>
                        <dd><a href="mailto:hello@anyoatdisenyo.ph">hello@anyoatdisenyo.ph</a><br>
                            <span class="meta" style="text-transform:none; letter-spacing:0; color:var(--tabako);">Email is the fastest way to reach the studio.</span></dd>
                    </div>
                    <div>
                        <dt>Phone</dt>
                        <dd><a href="tel:+63432000000">+63 43 200 0000</a><br>
                            <span class="meta" style="text-transform:none; letter-spacing:0; color:var(--tabako);">Mon — Fri, 9am – 6pm Philippine time.</span></dd>
                    </div>
                    <div>
                        <dt>Studio</dt>
                        <dd>Batangas City<br>
                            Batangas, Philippines<br>
                            <span class="meta" style="text-transform:none; letter-spacing:0; color:var(--tabako);">By appointment — the studio is not a walk-in office.</span></dd>
                    </div>
                    <div>
                        <dt>Elsewhere</dt>
                        <dd><a href="https://www.facebook.com/anyoatdisenyo" target="_blank" rel="noopener">Facebook · @anyoatdisenyo</a></dd>
                    </div>
                </dl>
            </aside>

            <div>
                <p style="font-family:'Fraunces',serif; font-style:italic; font-weight:300; font-size:1.25rem; line-height:1.5; color:var(--ink-soft); margin:0 0 2.5rem; max-width:42ch;">
                    A few sentences about the site, the project, and what you are working towards is enough to start. We will reply with next steps.
                </p>

                {# ---------- INQUIRY FORM ----------
                   The action below points at a Formspree placeholder. To enable real
                   submissions on the static site, create a Formspree endpoint at
                   https://formspree.io and replace REPLACE_ME with the form ID. #}
                <form action="https://formspree.io/f/REPLACE_ME"
                      method="POST"
                      class="contact-form"
                      aria-label="Project inquiry form">
                    <div class="row">
                        <label>
                            <span>Name</span>
                            <input type="text" name="name" required autocomplete="name">
                        </label>
                        <label>
                            <span>Email</span>
                            <input type="email" name="email" required autocomplete="email">
                        </label>
                    </div>
                    <div class="row">
                        <label>
                            <span>Phone (optional)</span>
                            <input type="tel" name="phone" autocomplete="tel">
                        </label>
                        <label>
                            <span>Project type</span>
                            <select name="project_type" required>
                                <option value="" selected>Choose one…</option>
                                <option value="Residence">New residence</option>
                                <option value="Renovation">Renovation</option>
                                <option value="Small commercial">Small commercial</option>
                                <option value="Interior fit-out">Interior fit-out</option>
                                <option value="Planning / feasibility">Planning / feasibility</option>
                                <option value="Other">Other</option>
                            </select>
                        </label>
                    </div>
                    <label>
                        <span>Project location</span>
                        <input type="text" name="location" placeholder="e.g. Lipa, Batangas">
                    </label>
                    <label>
                        <span>About the project</span>
                        <textarea name="message" rows="6" required placeholder="The site, the brief, and roughly when you'd like to start."></textarea>
                    </label>
                    {# Honeypot — hidden from real users, attracts bots. #}
                    <input type="text" name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true">
                    <button type="submit" class="btn btn-primary">Send inquiry</button>
                    <p style="font-size:.8125rem; color:var(--tabako); margin:0;">By sending, you agree we may store your message to reply to it. No newsletter, no list.</p>
                </form>
            </div>
        </div>
    </div>
</section>

{# ---------- MAP / ADDRESS CARD ---------- #}
<section class="section-sm" style="padding-top:0;">
    <div class="wrap">
        <span class="eyebrow">Find the studio</span>
        <h2 style="margin-top:.75rem; margin-bottom:2rem;">Based in Batangas City.</h2>
        <figure style="margin:0; border:1px solid var(--lime);">
            {# Contextual photo of the Batangas heritage setting — swap with a studio exterior when client supplies one. #}
            <img src="/uploads/batangas_sariayajf9900_03_jpg.jpg"
                 alt="Heritage Batangas street scene near the studio."
                 style="display:block; width:100%; height:auto; max-height:320px; object-fit:cover;"
                 loading="lazy">
            <iframe
                src="https://www.openstreetmap.org/export/embed.html?bbox=121.0470%2C13.7475%2C121.0770%2C13.7675&layer=mapnik&marker=13.7575%2C121.0620"
                width="100%"
                height="420"
                style="border:0; display:block;"
                loading="lazy"
                title="Map — Anyo at Disenyo studio, Batangas City"></iframe>
            <figcaption style="padding:1.5rem; background:var(--bone-2); display:flex; justify-content:space-between; gap:2rem; flex-wrap:wrap;">
                <div>
                    <strong style="font-family:'Fraunces',serif; font-weight:400; font-size:1.125rem;">Anyo at Disenyo</strong><br>
                    <span class="meta" style="text-transform:none; letter-spacing:0;">Batangas City, Batangas — Philippines</span>
                </div>
                <div style="display:flex; gap:1.5rem; align-items:center;">
                    <a href="https://www.openstreetmap.org/?mlat=13.7575&mlon=121.0620#map=15/13.7575/121.0620" target="_blank" rel="noopener" class="arrow-link">Open in OpenStreetMap</a>
                </div>
            </figcaption>
        </figure>
    </div>
</section>

{% endblock %}
