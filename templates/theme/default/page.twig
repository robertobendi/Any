{% extends '@theme/layout.twig' %}
{% set meta_description = entry.field('meta_description') %}

{% block title %}{{ entry.field('title') }} — Anyo at Disenyo{% endblock %}
{% block description %}{{ entry.field('meta_description') ?? entry.field('title') }}{% endblock %}

{% block content %}
<section class="page-intro">
    <div class="wrap">
        <div class="offset-col">
            <span class="eyebrow">Anyo at Disenyo</span>
            <h1>{{ entry.field('title') }}</h1>
        </div>
    </div>
</section>

<section class="section-sm" style="padding-top:0;">
    <div class="wrap">
        <div class="offset-col prose">
            {{ entry.field('body')|markdown|raw }}
        </div>
    </div>
</section>
{% endblock %}
